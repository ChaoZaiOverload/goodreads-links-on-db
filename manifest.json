{
  "manifest_version": 3,
  "name": "在豆瓣显示Goodreads链接和评分",
  "version": "1.2.0",
  "description": "Shows a Goodreads link next to the book title on Douban book pages。在豆瓣图书页，让你可以同时看到豆瓣和goodreads的链接和评分。",
  "permissions": ["webNavigation"],
  "host_permissions": [
    "https://book.douban.com/subject/*",
    "https://www.goodreads.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://book.douban.com/subject/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
